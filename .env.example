# ============================================================
# Frontend Environment Variables
# Add these in AWS Amplify Console → App Settings → Environment Variables
# DO NOT commit the actual .env file to GitHub
# ============================================================

# Your Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Your API Gateway URL (from Lambda step — looks like below)
# https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod
VITE_API_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod

# Same URL + /leads
VITE_LEADS_API_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod/leads
