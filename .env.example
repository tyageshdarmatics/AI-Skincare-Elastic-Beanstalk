# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# Never commit the actual .env file to GitHub!
# ============================================================

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- MongoDB Atlas ---
# Get this from Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/
MONGODB_DB=Skin-analysis-database
MONGODB_COLLECTION=Skin-analysis

# --- Server ---
PORT=8080

# --- AWS S3 (for image uploads) ---
APP_AWS_REGION=ap-south-1
APP_AWS_S3_BUCKET=your-s3-bucket-name
APP_AWS_ACCESS_KEY_ID=your_iam_access_key_id
APP_AWS_SECRET_ACCESS_KEY=your_iam_secret_access_key

# --- Frontend URLs (set these AFTER you deploy Amplify) ---
# Example: https://main.d1abc123.amplifyapp.com
VITE_API_URL=http://localhost:8080
VITE_LEADS_API_URL=http://localhost:8080/leads

# --- CORS (comma-separated list of allowed frontend origins) ---
# Add your Amplify URL here after deploying
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
